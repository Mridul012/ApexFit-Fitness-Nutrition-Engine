generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum GoalType {
  weight_loss
  muscle_gain
  maintenance
}

enum WorkoutType {
  cardio
  strength
  flexibility
}

enum RecType {
  diet_adjustment
  workout_change
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  passwordHash    String           @map("password_hash")
  fullName        String           @map("full_name")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  goal            Goal?
  meals           Meal[]
  workouts        Workout[]
  progress        Progress[]
  recommendations Recommendation[]

  @@map("users")
}

model Goal {
  id                  String   @id @default(uuid())
  userId              String   @unique @map("user_id")
  goalType            GoalType @map("goal_type")
  targetWeightKg      Decimal  @map("target_weight_kg") @db.Decimal(5, 2)
  targetDailyCalories Decimal  @map("target_daily_calories") @db.Decimal(7, 2)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("goals")
}

model Meal {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  mealName  String   @map("meal_name")
  calories  Decimal  @db.Decimal(7, 2)
  proteinG  Decimal  @map("protein_g") @db.Decimal(6, 2)
  carbsG    Decimal  @map("carbs_g") @db.Decimal(6, 2)
  fatG      Decimal  @map("fat_g") @db.Decimal(6, 2)
  loggedAt  DateTime @default(now()) @map("logged_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt], name: "idx_meals_user_date")
  @@map("meals")
}

model Workout {
  id             String      @id @default(uuid())
  userId         String      @map("user_id")
  workoutType    WorkoutType @map("workout_type")
  durationMins   Int         @map("duration_mins")
  caloriesBurned Decimal     @map("calories_burned") @db.Decimal(7, 2)
  loggedAt       DateTime    @default(now()) @map("logged_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt], name: "idx_workouts_user_date")
  @@map("workouts")
}

model Progress {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  weightKg          Decimal  @map("weight_kg") @db.Decimal(5, 2)
  bodyFatPercentage Decimal  @map("body_fat_percentage") @db.Decimal(4, 2)
  recordedAt        DateTime @default(now()) @map("recorded_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt], name: "idx_progress_user_recorded")
  @@map("progress")
}

model Recommendation {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  recType      RecType  @map("rec_type")
  message      String   @db.Text
  appliedRules Json     @map("applied_rules")
  isRead       Boolean  @default(false) @map("is_read")
  generatedAt  DateTime @default(now()) @map("generated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, generatedAt], name: "idx_recommendations_user_generated")
  @@index([userId, isRead], name: "idx_recommendations_user_read")
  @@map("recommendations")
}
